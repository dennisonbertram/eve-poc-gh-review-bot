# Copy to .env.local and fill in. NEVER commit real values — .env.local is gitignored.

# --- Model credential (required) ---
# The agent calls Anthropic directly via the @ai-sdk/anthropic provider.
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- GitHub access for the bot's tools (required) ---
# A token the bot uses to read PR diffs and post reviews.
# Local dev: a classic PAT or fine-grained PAT with "Pull requests: read & write"
#   on the target repo(s). Create at https://github.com/settings/tokens
# In GitHub Actions: use the built-in ${{ secrets.GITHUB_TOKEN }} instead (see workflow).
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Route auth for the bot's HTTP session API (required when deployed) ---
# The bot's session routes are protected by HTTP Basic (username "operator").
# Pick any strong secret; you'll pass it as the password when driving the bot.
ROUTE_AUTH_BASIC_PASSWORD=choose-a-long-random-string

# --- Production webhook channel (OPTIONAL: only for the GitHub App form) ---
# Needed only if you wire the agent/channels/github.ts webhook channel to a GitHub App.
# Create an App at https://github.com/settings/apps/new and copy these in.
# GITHUB_APP_ID=123456
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# GITHUB_WEBHOOK_SECRET=another-long-random-string
